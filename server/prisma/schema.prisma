  generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./godeo.db"
}

model User {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  password   String
  name       String
  role       String     @default("EMPLEADO")
  restaurant String
  createdAt  DateTime   @default(now())
  movements  Movement[]
  transfers  Transfer[]
}

model Product {
  id         Int        @id @default(autoincrement())
  name       String
  category   String
  stock      Float
  unit       String
  price      Float
  minStock   Float      @default(10)
  expiryDate DateTime?
  restaurant String
  createdAt  DateTime   @default(now())
  movements  Movement[]
  transfers  Transfer[]
  
  @@unique([name, restaurant])
}

model Movement {
  id         Int        @id @default(autoincrement())
  type       String
  quantity   Float
  reason     String?
  productId  Int
  userId     Int
  supplierId Int?
  restaurant String
  createdAt  DateTime   @default(now())
  product    Product    @relation(fields: [productId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  supplier   Supplier?  @relation(fields: [supplierId], references: [id])
}

model Transfer {
  id             Int        @id @default(autoincrement())
  productId      Int
  quantity       Float
  fromRestaurant String
  toRestaurant   String
  userId         Int
  reason         String?
  status         String     @default("pendiente")
  createdAt      DateTime   @default(now())
  completedAt    DateTime?
  product        Product    @relation(fields: [productId], references: [id])
  user           User       @relation(fields: [userId], references: [id])
}

model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  createdAt DateTime   @default(now())
  movements Movement[]
}
